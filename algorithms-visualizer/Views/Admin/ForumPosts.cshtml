@model IEnumerable<algorithms_visualizer.Models.Forum.ForumPost>

@{
    ViewData["Title"] = "Posty forum";
}

<h1>Posty forum</h1>
<p><a asp-action="Index">← Powrót do panelu</a></p>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zamknij"></button>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted">Brak postów na forum</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Tytuł</th>
                <th>Autor</th>
                <th>Kategoria</th>
                <th>Komentarzy</th>
                <th>Data</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model)
            {
                <tr>
                    <td>@post.Title</td>
                    <td>
                        @if (!string.IsNullOrEmpty(post.Author?.Nickname))
                        {
                            @post.Author.Nickname
                        }
                        else
                        {
                            <span class="text-muted">@post.Author?.Email</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-secondary">@post.Category?.Name</span>
                    </td>
                    <td>@post.Comments.Count</td>
                    <td>@post.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <form asp-action="DeleteForumPost" asp-route-id="@post.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Usunąć ten post?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
