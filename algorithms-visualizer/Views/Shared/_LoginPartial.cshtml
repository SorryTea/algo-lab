@using Microsoft.AspNetCore.Identity
@using algorithms_visualizer.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Admin" asp-action="Index">Admin</a>
            </li>
        }

        <li class="nav-item">
            @{
                var currentUser = await UserManager.GetUserAsync(User);
                var displayName = !string.IsNullOrEmpty(currentUser?.Nickname)
                    ? currentUser.Nickname
                    : User.Identity!.Name;
            }
            <a class="nav-link text-dark d-flex align-items-center gap-2" asp-area="Identity"
               asp-page="/Account/Manage/Index" title="Manage">
                @if (!string.IsNullOrEmpty(currentUser?.AvatarPath))
                {
                    <img src="@currentUser.AvatarPath" alt="Avatar" class="rounded-circle"
                         style="width:28px;height:28px;object-fit:cover;" />
                }
                <span>@displayName</span>
            </a>
        </li>

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>
